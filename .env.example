# Database
DATABASE_URL="postgresql://netchex:netchex_dev@localhost:5432/netchex_leads"

# App Auth (basic password protection)
APP_PASSWORD="changeme"

# Encryption key for stored API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="generate-a-64-char-hex-string-here"

# App
PORT=3000
NODE_ENV=development

# --- Integration API Keys (configure via Settings UI instead) ---
# These can also be set via the Settings page in the app.
# If set here, they'll be used as defaults.

# LLM (for email generation)
# LLM_PROVIDER=openai  # or "anthropic"
# LLM_API_KEY=

# Clay (primary enrichment)
# CLAY_API_KEY=
# CLAY_TABLE_ID=

# Apify (fallback enrichment)
# APIFY_API_KEY=
# APIFY_ACTOR_ID=

# Salesforce
# SF_CLIENT_ID=
# SF_CLIENT_SECRET=
# SF_REFRESH_TOKEN=
# SF_INSTANCE_URL=https://your-instance.my.salesforce.com

# Gong Engage
# GONG_API_KEY=
